---
interface Props {
  message: string;
  icon?: 'box' | 'image' | 'folder';
}

const { message, icon = 'box' } = Astro.props;

const icons = {
  box: `<svg class="w-16 h-16 text-secondary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
  </svg>`,
  image: `<svg class="w-16 h-16 text-secondary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
  </svg>`,
  folder: `<svg class="w-16 h-16 text-secondary/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
  </svg>`
};
---

<div class="flex flex-col items-center justify-center py-20 px-4">
  <div set:html={icons[icon]} />
  <p class="mt-4 text-lg text-extra-2 dark:text-secondary/70 text-center max-w-md">
    {message}
  </p>
</div>
