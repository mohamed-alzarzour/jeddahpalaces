---
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingActionButton from '../components/FloatingActionButton';
import EmptyState from '../components/EmptyState.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import { t, getLocaleString } from '../lib/i18n';
import type { Project } from '../lib/types';

const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

// Fetch active projects
let projects: Project[] = [];
try {
  projects = await sanityClient.fetch(`
    *[_type == "project" && (status == "active" || !defined(status))] | order(_createdAt desc) {
      _id,
      title,
      slug,
      status,
      description,
      location,
      startDate,
      beforeImage,
      afterImage,
      progressPhotos[] {
        image,
        caption,
        date
      },
      category,
      relatedProducts[]->{
        _id,
        name,
        slug
      }
    }
  `);
} catch (error) {
  console.error('Failed to fetch current projects:', error);
}
---

<BaseLayout 
  title={t('currentProjects', lang)}
  description={lang === 'ar' ? 'استكشف مشاريعنا الحالية قيد التنفيذ' : 'Explore our current projects under construction'}
>
  <FloatingActionButton client:load mode="simple" lang={lang} />

  <section class="py-20">
    <div class="container">
      <!-- Page Title -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          {t('currentProjects', lang)}
        </h1>
        <p class="text-lg text-extra-2 dark:text-secondary/70 max-w-2xl mx-auto">
          {lang === 'ar' 
            ? 'تابع مشاريعنا الحالية ورحلة البناء خطوة بخطوة'
            : 'Follow our current projects and the construction journey step by step'}
        </p>
      </div>

      {projects.length > 0 ? (
        <div class="space-y-16">
          {projects.map((project) => {
            const mainImage = project.afterImage || project.beforeImage;
            const photoCount = project.progressPhotos?.length || 0;
            return (
              <article class="bg-white dark:bg-primary/30 rounded-2xl overflow-hidden shadow-xl border border-secondary/10 hover:border-secondary/30 transition-all duration-300">
                <div class="grid lg:grid-cols-2 gap-0">
                  {/* Image Section */}
                  <div class="relative aspect-video lg:aspect-auto lg:min-h-[400px]">
                    {mainImage ? (
                      <img
                        src={urlFor(mainImage).width(800).height(600).fit('crop').quality(85).url()}
                        alt={getLocaleString(project.title, lang)}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    ) : photoCount > 0 ? (
                      <img
                        src={urlFor(project.progressPhotos![0].image).width(800).height(600).fit('crop').quality(85).url()}
                        alt={getLocaleString(project.title, lang)}
                        class="w-full h-full object-cover"
                        loading="lazy"
                      />
                    ) : (
                      <div class="w-full h-full min-h-[300px] bg-gradient-to-br from-secondary/20 to-accent/20 flex items-center justify-center">
                        <svg class="w-16 h-16 text-secondary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                        </svg>
                      </div>
                    )}
                    {/* Status Badge */}
                    <div class="absolute top-4 start-4">
                      <span class="px-4 py-2 bg-amber-500/90 text-white text-sm font-bold rounded-full backdrop-blur-sm flex items-center gap-2">
                        <span class="w-2 h-2 bg-white rounded-full animate-pulse"></span>
                        {t('active', lang)}
                      </span>
                    </div>
                    {/* Photo Count */}
                    {photoCount > 0 && (
                      <div class="absolute bottom-4 end-4">
                        <span class="px-3 py-1.5 bg-black/60 text-white text-sm rounded-full backdrop-blur-sm flex items-center gap-1.5">
                          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                          </svg>
                          {photoCount} {t('photos', lang)}
                        </span>
                      </div>
                    )}
                  </div>

                  {/* Info Section */}
                  <div class="p-8 lg:p-10 flex flex-col justify-between">
                    <div>
                      <h2 class="text-2xl md:text-3xl font-bold mb-4">
                        {getLocaleString(project.title, lang)}
                      </h2>

                      {project.description && (
                        <p class="text-extra-2 dark:text-secondary/70 mb-6 leading-relaxed line-clamp-3">
                          {getLocaleString(project.description, lang)}
                        </p>
                      )}

                      {/* Meta Info */}
                      <div class="flex flex-wrap gap-3 mb-6">
                        {project.location && (
                          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-secondary/10 rounded-lg text-sm">
                            <svg class="w-4 h-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                            {getLocaleString(project.location, lang)}
                          </span>
                        )}
                        {project.startDate && (
                          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-secondary/10 rounded-lg text-sm">
                            <svg class="w-4 h-4 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                            {project.startDate}
                          </span>
                        )}
                        {project.category && (
                          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-secondary/10 rounded-lg text-sm">
                            {project.category === 'interior' ? (lang === 'ar' ? 'داخلي' : 'Interior') :
                             project.category === 'exterior' ? (lang === 'ar' ? 'خارجي' : 'Exterior') :
                             (lang === 'ar' ? 'داخلي وخارجي' : 'Interior & Exterior')}
                          </span>
                        )}
                      </div>

                      {/* Materials Used */}
                      {project.relatedProducts && project.relatedProducts.length > 0 && (
                        <div class="mb-6">
                          <h3 class="text-sm font-semibold text-extra-2 dark:text-secondary/50 uppercase tracking-wider mb-2">
                            {t('materialsUsed', lang)}
                          </h3>
                          <div class="flex flex-wrap gap-2">
                            {project.relatedProducts.map((product) => (
                              <a
                                href={`/products/${product.slug.current}`}
                                class="px-3 py-1 text-sm bg-extra-1 dark:bg-primary/50 rounded-full border border-secondary/15 hover:border-secondary hover:text-secondary transition-all duration-200"
                              >
                                {getLocaleString(product.name, lang)}
                              </a>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>

                    {/* View Button */}
                    <a
                      href={`/project/${project.slug.current}`}
                      class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-gradient-to-r from-secondary to-accent text-white font-semibold rounded-lg hover:shadow-xl hover:scale-105 transition-all duration-300 mt-4"
                    >
                      {t('viewProject', lang)}
                      <svg class="w-5 h-5 rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                      </svg>
                    </a>
                  </div>
                </div>

                {/* Progress Photos Strip */}
                {photoCount > 1 && (
                  <div class="border-t border-secondary/10 px-8 py-5 bg-extra-1/50 dark:bg-black/20">
                    <h3 class="text-sm font-semibold text-extra-2 dark:text-secondary/50 uppercase tracking-wider mb-3">
                      {t('progressPhotos', lang)}
                    </h3>
                    <div class="flex gap-3 overflow-x-auto pb-2 scrollbar-thin">
                      {project.progressPhotos!.slice(0, 8).map((photo, i) => (
                        <img
                          src={urlFor(photo.image).width(150).height(150).fit('crop').quality(75).url()}
                          alt={getLocaleString(photo.caption, lang) || `Progress ${i + 1}`}
                          class="w-20 h-20 md:w-24 md:h-24 rounded-lg object-cover flex-shrink-0 border-2 border-transparent hover:border-secondary transition-all duration-200"
                          loading="lazy"
                        />
                      ))}
                      {photoCount > 8 && (
                        <a
                          href={`/project/${project.slug.current}`}
                          class="w-20 h-20 md:w-24 md:h-24 rounded-lg flex-shrink-0 bg-secondary/10 flex items-center justify-center text-secondary font-bold hover:bg-secondary/20 transition-all duration-200"
                        >
                          +{photoCount - 8}
                        </a>
                      )}
                    </div>
                  </div>
                )}
              </article>
            );
          })}
        </div>
      ) : (
        <EmptyState
          message={t('noCurrentProjects', lang)}
          icon="building"
        />
      )}
    </div>
  </section>
</BaseLayout>
