---
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingActionButton from '../components/FloatingActionButton';
import ContactForm from '../components/ContactForm';
import SocialLink from '../components/SocialLink.astro';
import { sanityClient } from '../lib/sanity';
import { getLanguage, t, getLocaleString } from '../lib/i18n';
import type { ContactInfo } from '../lib/types';

const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

// Fetch contact info
let contactInfo: ContactInfo | null = null;
try {
  contactInfo = await sanityClient.fetch(`*[_type == "contactInfo"][0]`);
} catch (error) {
  console.error('Failed to fetch contact info:', error);
}
---

<BaseLayout 
  title={t('contact', lang)}
  description={lang === 'ar' ? 'تواصل معنا لأي استفسارات أو مشاريع' : 'Get in touch with us for any inquiries or projects'}
>
  <FloatingActionButton client:load mode="simple" lang={lang} />
  <section class="py-20 relative overflow-hidden">
    <!-- Background Animation -->
    <div class="absolute inset-0 -z-10 overflow-hidden">
      <div class="absolute top-1/4 -start-20 w-96 h-96 bg-secondary/10 rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-1/4 -end-20 w-96 h-96 bg-accent/10 rounded-full blur-3xl animate-pulse" style="animation-delay: 2s;"></div>
    </div>
    <div class="container">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          {t('contact', lang)}
        </h1>
        <p class="text-lg text-extra-2 dark:text-secondary/70 max-w-2xl mx-auto">
          {lang === 'ar'
            ? 'نحن هنا للإجابة على أسئلتك ومساعدتك في تحقيق رؤيتك'
            : "We're here to answer your questions and help you achieve your vision"
          }
        </p>
      </div>

      <div class="grid lg:grid-cols-5 gap-12 max-w-6xl mx-auto">
        <!-- Contact Info Cards (Left) -->
        <div class="lg:col-span-2 space-y-6">
          {/* Email Card */}
          {contactInfo?.email && (
            <div class="group bg-white dark:bg-primary/30 rounded-xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-secondary to-accent flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-7 h-7 text-white group-hover:animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-lg mb-1">{lang === 'ar' ? 'البريد الإلكتروني' : 'Email'}</h3>
                  <a href={`mailto:${contactInfo.email}`} class="text-secondary hover:text-accent transition-colors break-all">
                    {contactInfo.email}
                  </a>
                </div>
              </div>
            </div>
          )}

          {/* Phone Card */}
          {contactInfo?.phone && (
            <div class="group bg-white dark:bg-primary/30 rounded-xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-accent to-secondary flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-7 h-7 text-white group-hover:animate-shake" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-lg mb-1">{lang === 'ar' ? 'الهاتف' : 'Phone'}</h3>
                  <a href={`tel:${contactInfo.phone}`} class="text-secondary hover:text-accent transition-colors">
                    {contactInfo.phone}
                  </a>
                </div>
              </div>
            </div>
          )}

          {/* Address Card */}
          {contactInfo?.address && (
            <div class="group bg-white dark:bg-primary/30 rounded-xl p-6 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-full bg-gradient-to-br from-secondary to-extra-2 flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform duration-300">
                  <svg class="w-7 h-7 text-white group-hover:animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-bold text-lg mb-1">{lang === 'ar' ? 'العنوان' : 'Address'}</h3>
                  <p class="text-extra-2 dark:text-secondary/70">
                    {getLocaleString(contactInfo.address, lang)}
                  </p>
                </div>
              </div>
            </div>
          )}

          {/* Social Media */}
          {contactInfo?.socialMedia && contactInfo.socialMedia.length > 0 && (
            <div class="bg-white dark:bg-primary/30 rounded-xl p-6 shadow-lg">
              <h3 class="font-bold text-lg mb-4">
                {lang === 'ar' ? 'تابعنا' : 'Follow Us'}
              </h3>
              <div class="flex gap-3">
                {contactInfo.socialMedia.map((social) => (
                  <SocialLink 
                    platform={social.platform} 
                    url={social.url} 
                    size="lg"
                  />
                ))}
              </div>
            </div>
          )}
        </div>

        <!-- Contact Form (Right) -->
        <div class="lg:col-span-3">
          <div class="bg-white dark:bg-primary/30 rounded-2xl p-8 md:p-10 shadow-2xl">
            <h2 class="text-3xl font-bold mb-6">
              {lang === 'ar' ? 'أرسل لنا رسالة' : 'Send us a Message'}
            </h2>
            <ContactForm client:load />
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-20px);
    }
  }
</style>
