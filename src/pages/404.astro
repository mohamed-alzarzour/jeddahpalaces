---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n';

const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';
---

<BaseLayout title={lang === 'ar' ? 'الصفحة غير موجودة' : 'Page Not Found'}>
  <section class="min-h-[70vh] flex items-center justify-center relative overflow-hidden">
    <!-- Decorative Background -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-1/4 -start-20 w-96 h-96 bg-secondary/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-1/4 -end-20 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container text-center">
      <!-- 404 Number -->
      <div class="relative inline-block mb-8">
        <span class="text-[10rem] md:text-[14rem] font-bold leading-none text-secondary/10 select-none">
          404
        </span>
        <div class="absolute inset-0 flex items-center justify-center">
          <svg class="w-24 h-24 md:w-32 md:h-32 text-secondary/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
      </div>

      <!-- Message -->
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        {lang === 'ar' ? 'الصفحة غير موجودة' : 'Page Not Found'}
      </h1>
      <p class="text-lg text-extra-2 dark:text-secondary/70 mb-10 max-w-md mx-auto">
        {lang === 'ar'
          ? 'عذراً، الصفحة التي تبحث عنها غير موجودة أو تم نقلها'
          : "Sorry, the page you're looking for doesn't exist or has been moved"
        }
      </p>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a 
          href="/"
          class="inline-block px-8 py-4 bg-gradient-to-r from-secondary to-accent text-white font-semibold rounded-lg hover:shadow-2xl hover:scale-105 transition-all duration-300 min-w-[200px]"
        >
          {lang === 'ar' ? 'العودة للرئيسية' : 'Back to Home'}
        </a>
        <a 
          href="/contact"
          class="inline-block px-8 py-4 bg-white dark:bg-primary border-2 border-secondary text-secondary font-semibold rounded-lg hover:bg-secondary hover:text-white transition-all duration-300 min-w-[200px]"
        >
          {t('contactUs', lang)}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
