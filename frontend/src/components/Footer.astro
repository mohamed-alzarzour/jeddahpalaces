---
import { sanityClient } from '../lib/sanity';
import type { ContactInfo } from '../lib/types';
import { getLanguage, t, getLocaleString } from '../lib/i18n';
import SocialLink from './SocialLink.astro';

const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

let contactInfo: ContactInfo | null = null;
try {
  contactInfo = await sanityClient.fetch(`*[_type == "contactInfo"][0]`);
} catch (error) {
  console.error('Failed to fetch contact info:', error);
}

const currentYear = new Date().getFullYear();
---

<footer class="bg-primary dark:bg-primary/50 text-extra-1 dark:text-extra-1 py-12 mt-20 border-t border-secondary/20">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <!-- Company Info -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img 
            src="/logo.png" 
            alt="Jeddah Palaces Logo" 
            class="w-16 h-16 object-contain"
          />
          <div class="flex flex-col">
            <span class="font-bold text-lg leading-tight">Jeddah Palaces</span>
            <span class="text-sm text-secondary">{lang === 'ar' ? 'للحجر الطبيعي' : 'Natural Stone'}</span>
          </div>
        </div>
        <p class="text-sm text-extra-2 dark:text-secondary/80 leading-relaxed">
          {lang === 'ar' 
            ? 'شركة متخصصة في تصميم وتوريد الديكورات الداخلية والخارجية والحجر الطبيعي'
            : 'Specialized in interior and exterior design, natural stone supply and finishing projects'
          }
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-bold text-lg mb-4">{lang === 'ar' ? 'روابط سريعة' : 'Quick Links'}</h3>
        <ul class="space-y-2">
          <li><a href="/" class="text-sm hover:text-secondary transition-colors">{t('home', lang)}</a></li>
          <li><a href="/products" class="text-sm hover:text-secondary transition-colors">{t('products', lang)}</a></li>
          <li><a href="/portfolio" class="text-sm hover:text-secondary transition-colors">{t('portfolio', lang)}</a></li>
          <li><a href="/current-projects" class="text-sm hover:text-secondary transition-colors">{t('currentProjects', lang)}</a></li>
          <li><a href="/gallery" class="text-sm hover:text-secondary transition-colors">{t('gallery', lang)}</a></li>
          <li><a href="/services" class="text-sm hover:text-secondary transition-colors">{t('services', lang)}</a></li>
          <li><a href="/about" class="text-sm hover:text-secondary transition-colors">{t('about', lang)}</a></li>
          <li><a href="/contact" class="text-sm hover:text-secondary transition-colors">{t('contact', lang)}</a></li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="font-bold text-lg mb-4">{t('contact', lang)}</h3>
        <div class="space-y-3">
          {contactInfo?.email && (
            <a href={`mailto:${contactInfo.email}`} class="flex items-center gap-2 text-sm hover:text-secondary transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <span>{contactInfo.email}</span>
            </a>
          )}
          {contactInfo?.phone && (
            <a href={`tel:${contactInfo.phone}`} class="flex items-center gap-2 text-sm hover:text-secondary transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span>{contactInfo.phone}</span>
            </a>
          )}
          {contactInfo?.socialMedia && contactInfo.socialMedia.filter(s => s.url).length > 0 && (
            <div class="flex gap-3 mt-4">
              {contactInfo.socialMedia.filter(s => s.url).map((social) => (
                <SocialLink 
                  platform={social.platform} 
                  url={social.url} 
                  size="md"
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </div>

    <div class="border-t border-secondary/20 pt-6 text-center space-y-2">
      <p class="text-sm text-extra-2 dark:text-secondary/70">
        © {currentYear} Jeddah Palaces for Natural Stone. {lang === 'ar' ? 'جميع الحقوق محفوظة' : 'All rights reserved'}.
      </p>
      <p class="text-xs text-extra-2/70 dark:text-secondary/50">
        {lang === 'ar' ? 'تطوير: م.' : 'Developed by: Eng.'}
        <a 
          href="https://www.linkedin.com/in/mohamed-alzarzour/" 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-secondary hover:text-accent transition-colors underline underline-offset-2"
        >
          {lang === 'ar' ? 'محمد أحمد الزرزور' : 'Mohamed Ahmed Alzarzour'}
        </a>
      </p>
      <p class="text-xs text-extra-2/70 dark:text-secondary/50">
        <a 
          href="https://github.com/mohamed-alzarzour/jeddahpalaces" 
          target="_blank" 
          rel="noopener noreferrer"
          class="text-secondary hover:text-accent transition-colors underline underline-offset-2"
        >
          GitHub
        </a>
      </p>
    </div>
  </div>
</footer>
