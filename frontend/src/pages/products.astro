---
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingActionButton from '../components/FloatingActionButton';
import ProductImageSlider from '../components/ProductImageSlider';
import EmptyState from '../components/EmptyState.astro';
import { sanityClient, urlFor } from '../lib/sanity';
import { getLanguage, t, getLocaleString } from '../lib/i18n';
import type { Product } from '../lib/types';

const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

// Fetch all products
let products: Product[] = [];
try {
  products = await sanityClient.fetch(`
    *[_type == "product"] | order(_createdAt desc)
  `);
} catch (error) {
  console.error('Failed to fetch products:', error);
}

// Extract existing categories and labels for filters
const existingCategories = [...new Set(products.map(p => p.category).filter(Boolean))] as string[];
const categoryLabels: Record<string, Record<string, string>> = {
  'natural-stone': { ar: 'حجر طبيعي', en: 'Natural Stone' },
  marble: { ar: 'رخام', en: 'Marble' },
  granite: { ar: 'جرانيت', en: 'Granite' },
  grc: { ar: 'GRC', en: 'GRC' },
  accessories: { ar: 'إكسسوارات', en: 'Accessories' },
};
---

<BaseLayout 
  title={t('products', lang)}
  description={lang === 'ar' ? 'استكشف مجموعتنا من الحجر الطبيعي والمواد الفاخرة' : 'Explore our collection of natural stone and premium materials'}
>
  <FloatingActionButton client:load mode="simple" lang={lang} />
  <section class="py-20">
    <div class="container">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          {t('products', lang)}
        </h1>
        <p class="text-lg text-extra-2 dark:text-secondary/70 max-w-2xl mx-auto">
          {lang === 'ar'
            ? 'اكتشف مجموعتنا الحصرية من الحجر الطبيعي والرخام والجرانيت والإكسسوارات الفاخرة'
            : 'Discover our exclusive collection of natural stone, marble, granite, and premium accessories'
          }
        </p>
      </div>

      {products.length > 0 ? (
        <>
          {/* Category Filters */}
          {existingCategories.length > 1 && (
            <div class="flex flex-wrap justify-center gap-3 mb-10" id="product-filters">
              <button
                data-category="all"
                class="product-filter active px-5 py-2 rounded-full text-sm font-medium border-2 border-secondary bg-secondary text-white transition-all duration-300 hover:scale-105"
              >
                {lang === 'ar' ? 'الكل' : 'All'}
              </button>
              {existingCategories.map((cat) => (
                <button
                  data-category={cat}
                  class="product-filter px-5 py-2 rounded-full text-sm font-medium border-2 border-secondary/30 text-extra-2 dark:text-secondary/70 hover:border-secondary hover:text-secondary transition-all duration-300 hover:scale-105"
                >
                  {categoryLabels[cat]?.[lang] || cat.replace('-', ' ').toUpperCase()}
                </button>
              ))}
            </div>
          )}

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            {products.map((product) => {
              const galleryImages = product.gallery 
                ? [product.mainImage, ...product.gallery]
                : [product.mainImage];
              
              const imageUrls = galleryImages.map(img => 
                urlFor(img).width(600).height(600).fit('crop').quality(85).url()
              );

              return (
                <div class="product-card group relative bg-white dark:bg-primary/30 rounded-lg overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-2" data-category={product.category || ''}>
                  {/* Image Gallery */}
                  <div class="relative aspect-square overflow-hidden">
                    <ProductImageSlider
                      client:visible
                      images={imageUrls}
                      autoRotate={true}
                      interval={4000}
                    />
                    
                  </div>
                  {/* Product Info */}
                  <div class="p-5 flex flex-col flex-grow">
                    <h3 class="text-xl font-bold mb-2 line-clamp-2">
                      {getLocaleString(product.name, lang)}
                    </h3>
                    
                    <div class="mb-4">
                      {product.category && (
                        <span class="inline-block px-3 py-1 bg-secondary/10 text-secondary text-sm font-medium rounded-full">
                          {product.category.replace('-', ' ').toUpperCase()}
                        </span>
                      )}
                    </div>

                    <div class="mt-auto pt-4 border-t border-secondary/10 opacity-0 group-hover:opacity-100 transition-all duration-300 transform translate-y-2 group-hover:translate-y-0">
                      <a 
                        href={`/products/${product.slug.current}`}
                        class="block w-full text-center px-4 py-2 bg-secondary hover:bg-accent text-white font-semibold rounded-lg transition-colors duration-300"
                      >
                        {t('aboutProduct', lang)}
                      </a>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>
        </>
      ) : (
        <EmptyState
          message={t('noProducts', lang)}
          icon="box"
        />
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  function initProductFilters() {
    const filterBtns = document.querySelectorAll('.product-filter');
    const productCards = document.querySelectorAll('.product-card');

    if (!filterBtns.length || !productCards.length) return;

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const category = (btn as HTMLElement).dataset.category || 'all';

        // Filter cards
        productCards.forEach(card => {
          const cardCat = (card as HTMLElement).dataset.category;
          if (category === 'all' || cardCat === category) {
            (card as HTMLElement).style.display = '';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });

        // Update active button styles
        filterBtns.forEach(b => {
          if (b === btn) {
            b.classList.add('bg-secondary', 'text-white', 'border-secondary');
            b.classList.remove('border-secondary/30', 'text-extra-2', 'dark:text-secondary/70');
          } else {
            b.classList.remove('bg-secondary', 'text-white', 'border-secondary');
            b.classList.add('border-secondary/30', 'text-extra-2', 'dark:text-secondary/70');
          }
        });
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initProductFilters);
  document.addEventListener('astro:page-load', initProductFilters);
</script>
