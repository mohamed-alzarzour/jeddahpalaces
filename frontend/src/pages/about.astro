---
import BaseLayout from '../layouts/BaseLayout.astro';
import FloatingActionButton from '../components/FloatingActionButton';
import { sanityClient, urlFor } from '../lib/sanity';
import { getLanguage, t, getLocaleString } from '../lib/i18n';
import SocialLink from '../components/SocialLink.astro';
import type { AboutPage, ContactInfo } from '../lib/types';

const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

// Fetch about page
let aboutPage: AboutPage | null = null;
try {
  aboutPage = await sanityClient.fetch(`*[_type == "aboutPage"][0]`);
} catch (error) {
  console.error('Failed to fetch about page:', error);
}

// Fetch contact info
let contactInfo: ContactInfo | null = null;
try {
  contactInfo = await sanityClient.fetch(`*[_type == "contactInfo"][0]`);
} catch (error) {
  console.error('Failed to fetch contact info:', error);
}
---

<BaseLayout 
  title={t('about', lang)}
  description={lang === 'ar' ? 'تعرف على فريقنا وخبرتنا في مجال التصميم والحجر الطبيعي' : 'Learn about our team and expertise in design and natural stone'}
>
  <FloatingActionButton client:load mode="simple" lang={lang} />
  <!-- Top Section: Engineer/Company Info -->
  <section class="py-20 bg-gradient-to-br from-extra-1 via-white to-secondary/10 dark:from-primary dark:via-primary/90 dark:to-accent/20 overflow-hidden">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Engineer Photo (Top on Mobile, Right on PC) -->
        <div class="relative animate-slide-in-left order-1 lg:order-2">
          {aboutPage?.photo ? (
            <div class="relative">
              <img 
                src={urlFor(aboutPage.photo).width(800).quality(90).url()}
                alt={getLocaleString(aboutPage.engineerName, lang)}
                class="w-full h-auto max-h-[600px] object-contain drop-shadow-2xl rounded-2xl"
              />
              {/* Decorative Elements */}
              <div class="absolute -z-10 top-1/4 -start-10 w-72 h-72 bg-secondary/20 rounded-full blur-3xl"></div>
              <div class="absolute -z-10 bottom-1/4 -end-10 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
            </div>
          ) : (
            <div class="aspect-square bg-gradient-to-br from-secondary to-accent rounded-2xl"></div>
          )}
        </div>

        <!-- Bio & Experience (Bottom on Mobile, Left on PC) -->
        <div class="space-y-6 animate-slide-in-right order-2 lg:order-1">
          {aboutPage?.engineerName && (
            <h1 class="text-4xl md:text-5xl font-bold">
              {getLocaleString(aboutPage.engineerName, lang)}
            </h1>
          )}

          {aboutPage?.bio && (
            <div>
              <h2 class="text-2xl font-semibold mb-3 text-secondary">
                {lang === 'ar' ? 'نبذة عنا' : 'About Us'}
              </h2>
              <p class="text-lg text-extra-2 dark:text-secondary/80 leading-relaxed whitespace-pre-line">
                {getLocaleString(aboutPage.bio, lang)}
              </p>
            </div>
          )}

          {aboutPage?.experience && (
            <div>
              <h2 class="text-2xl font-semibold mb-3 text-secondary">
                {lang === 'ar' ? 'الخبرة' : 'Experience'}
              </h2>
              <p class="text-lg text-extra-2 dark:text-secondary/80 leading-relaxed whitespace-pre-line">
                {getLocaleString(aboutPage.experience, lang)}
              </p>
            </div>
          )}

          {aboutPage?.expertise && (
            <div>
              <h2 class="text-2xl font-semibold mb-3 text-secondary">
                {lang === 'ar' ? 'مجالات التخصص' : 'Expertise'}
              </h2>
              <p class="text-lg text-extra-2 dark:text-secondary/80 leading-relaxed whitespace-pre-line">
                {getLocaleString(aboutPage.expertise, lang)}
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom Section: Philosophy & Contact -->
  <section class="py-20">
    <div class="container max-w-4xl">
      {aboutPage?.philosophy && (
        <div class="mb-16 text-center">
          <h2 class="text-3xl md:text-4xl font-bold mb-6">
            {lang === 'ar' ? 'فلسفتنا' : 'Our Philosophy'}
          </h2>
          <p class="text-xl text-extra-2 dark:text-secondary/80 leading-relaxed whitespace-pre-line">
            {getLocaleString(aboutPage.philosophy, lang)}
          </p>
        </div>
      )}

      {/* Contact Information */}
      <div class="bg-gradient-to-br from-primary to-extra-2 dark:from-extra-2 dark:to-primary text-white rounded-2xl p-8 md:p-12">
        <h2 class="text-3xl font-bold mb-8 text-center">
          {t('contact', lang)}
        </h2>

        <div class="grid md:grid-cols-2 gap-6">
          {contactInfo?.email && (
            <a 
              href={`mailto:${contactInfo.email}`}
              class="flex items-center gap-4 p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-all duration-300"
            >
              <svg class="w-8 h-8 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <div>
                <div class="text-sm text-secondary/80">{lang === 'ar' ? 'البريد الإلكتروني' : 'Email'}</div>
                <div class="font-semibold">{contactInfo.email}</div>
              </div>
            </a>
          )}

          {contactInfo?.phone && (
            <a 
              href={`tel:${contactInfo.phone}`}
              class="flex items-center gap-4 p-4 bg-white/10 rounded-lg hover:bg-white/20 transition-all duration-300"
            >
              <svg class="w-8 h-8 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <div>
                <div class="text-sm text-secondary/80">{lang === 'ar' ? 'الهاتف' : 'Phone'}</div>
                <div class="font-semibold">{contactInfo.phone}</div>
              </div>
            </a>
          )}
        </div>

        {/* Social Media */}
        {contactInfo?.socialMedia && contactInfo.socialMedia.length > 0 && (
          <div class="mt-8 text-center">
            <div class="text-sm text-secondary/80 mb-4">
              {lang === 'ar' ? 'تابعنا' : 'Follow Us'}
            </div>
            <div class="flex justify-center gap-4">
              {contactInfo.socialMedia.map((social) => (
                <SocialLink 
                  platform={social.platform} 
                  url={social.url} 
                  size="lg"
                />
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
