---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BeforeAfterSlider from '../../components/BeforeAfterSlider';
import FloatingActionButton from '../../components/FloatingActionButton';
import { sanityClient, urlFor } from '../../lib/sanity';
import { getLocaleString, t } from '../../lib/i18n';
import type { Project } from '../../lib/types';

export const prerender = false; // Ensure SSR

const { slug } = Astro.params;
const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

if (!slug) {
  return Astro.redirect('/404');
}

// Fetch project
const project: Project = await sanityClient.fetch(`
  *[_type == "project" && slug.current == $slug][0]{
    ...,
    progressPhotos[] {
      image,
      caption,
      date
    },
    relatedProducts[]->{
      _id,
      name,
      slug
    }
  }
`, { slug });

if (!project) {
  return Astro.redirect('/404');
}

const title = getLocaleString(project.title, lang);
const isCompleted = project.status === 'completed';
const mainImage = project.afterImage || project.beforeImage;
const hasBeforeAfter = project.beforeImage && project.afterImage;
---

<BaseLayout 
  title={title}
  description={getLocaleString(project.description, lang)}
  image={mainImage ? urlFor(mainImage).width(1200).url() : undefined}
>
  <FloatingActionButton client:load mode="simple" lang={lang} />

  <!-- 1. Project Name -->
  <section class="pt-32 pb-10 bg-extra-1 dark:bg-primary text-center">
    <div class="container">
      <h1 class="text-4xl md:text-6xl font-bold text-primary dark:text-white mb-4">
        {title}
      </h1>
      <div class="flex items-center justify-center gap-4 text-sm md:text-base text-secondary">
        {/* Status Badge */}
        <span class={`px-4 py-1.5 rounded-full font-medium flex items-center gap-2 ${
          isCompleted 
            ? 'bg-green-500/10 text-green-600 dark:text-green-400' 
            : 'bg-amber-500/10 text-amber-600 dark:text-amber-400'
        }`}>
          {isCompleted ? (
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          ) : (
            <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
          )}
          {isCompleted ? t('completed', lang) : t('active', lang)}
        </span>
        {project.category && (
          <span class="px-3 py-1 bg-secondary/10 rounded-full">
            {project.category === 'interior' ? (lang === 'ar' ? 'داخلي' : 'Interior') :
             project.category === 'exterior' ? (lang === 'ar' ? 'خارجي' : 'Exterior') :
             (lang === 'ar' ? 'داخلي وخارجي' : 'Interior & Exterior')}
          </span>
        )}
        {project.year && (
          <span class="px-3 py-1 bg-secondary/10 rounded-full">
            {project.year}
          </span>
        )}
      </div>
      {/* Location & Start Date */}
      <div class="flex items-center justify-center gap-6 mt-4 text-sm text-extra-2 dark:text-secondary/60">
        {project.location && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {getLocaleString(project.location, lang)}
          </span>
        )}
        {project.startDate && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {project.startDate}
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- 2. Before & After Slider OR Main Image -->
  <section class="w-full h-[60vh] md:h-[80vh] relative bg-black">
    {hasBeforeAfter ? (
      <BeforeAfterSlider 
        client:visible
        beforeImage={urlFor(project.beforeImage!).width(1920).quality(90).url()}
        afterImage={urlFor(project.afterImage!).width(1920).quality(90).url()}
        beforeAlt={lang === 'ar' ? 'قبل' : 'Before'}
        afterAlt={lang === 'ar' ? 'بعد' : 'After'}
      />
    ) : mainImage ? (
      <img
        src={urlFor(mainImage).width(1920).quality(90).url()}
        alt={getLocaleString(project.title, lang)}
        class="w-full h-full object-cover"
      />
    ) : null}
  </section>

  <!-- 3. Project Info -->
  <section class="py-20 bg-white dark:bg-primary/50">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-8 text-center">
          {lang === 'ar' ? 'تفاصيل المشروع' : 'Project Details'}
        </h2>
        
        {project.description && (
          <div class="prose dark:prose-invert max-w-none mb-12 text-lg leading-relaxed text-center">
            <p>{getLocaleString(project.description, lang)}</p>
          </div>
        )}

        {/* Materials Used */}
        {project.relatedProducts && project.relatedProducts.length > 0 && (
          <div class="bg-extra-1 dark:bg-primary p-8 rounded-2xl border border-secondary/10">
            <h3 class="text-xl font-bold mb-6 text-center">
              {t('materialsUsed', lang)}
            </h3>
            <div class="flex flex-wrap justify-center gap-4">
              {project.relatedProducts.map((product) => (
                <a
                  href={`/products/${product.slug.current}`}
                  class="flex items-center gap-2 px-6 py-3 bg-white dark:bg-primary/50 rounded-lg shadow-sm hover:shadow-md hover:scale-105 transition-all duration-300 border border-secondary/20"
                >
                  <span class="font-medium">
                    {getLocaleString(product.name, lang)}
                  </span>
                  <svg class="w-4 h-4 text-secondary rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  {!isCompleted && project.progressPhotos && project.progressPhotos.length > 0 && (
    <!-- Active: Progress Photos (progressPhotos + gallery merged) -->
    <section class="py-20 bg-extra-1/30 dark:bg-black/20">
      <div class="container">
        <h2 class="text-3xl font-bold mb-12 text-center">
          {t('progressPhotos', lang)}
        </h2>
        
        {project.progressPhotos && project.progressPhotos.length > 0 && (
          <div class="project-photo-grid grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 mb-12">
            {project.progressPhotos
              .sort((a, b) => {
                if (!a.date && !b.date) return 0;
                if (!a.date) return 1;
                if (!b.date) return -1;
                return new Date(b.date).getTime() - new Date(a.date).getTime();
              })
              .map((photo, i) => (
              <div class="project-photo-item group relative aspect-square overflow-hidden rounded-xl shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 cursor-zoom-in">
                <img
                  src={urlFor(photo.image).width(400).height(400).fit('crop').quality(80).url()}
                  alt={getLocaleString(photo.caption, lang) || `Progress ${i + 1}`}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3">
                  {photo.caption && (
                    <p class="text-white text-sm font-medium truncate">
                      {getLocaleString(photo.caption, lang)}
                    </p>
                  )}
                  {photo.date && (
                    <p class="text-white/70 text-xs mt-1">{photo.date}</p>
                  )}
                </div>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <svg class="w-8 h-8 text-white drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                  </svg>
                </div>
                <input type="hidden" class="full-url" value={urlFor(photo.image).width(1920).quality(90).url()} />
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {isCompleted && project.progressPhotos && project.progressPhotos.length > 0 && (
    <!-- Completed: Project Gallery (progressPhotos + gallery combined) -->
    <section class="py-20 bg-extra-1/30 dark:bg-black/20">
      <div class="container">
        <h2 class="text-3xl font-bold mb-12 text-center">
          {lang === 'ar' ? 'معرض المشروع' : 'Project Gallery'}
        </h2>
        
        {/* Progress photos as grid */}
        {project.progressPhotos && project.progressPhotos.length > 0 && (
          <div class="project-photo-grid grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 mb-12">
            {project.progressPhotos
              .sort((a, b) => {
                if (!a.date && !b.date) return 0;
                if (!a.date) return 1;
                if (!b.date) return -1;
                return new Date(b.date).getTime() - new Date(a.date).getTime();
              })
              .map((photo, i) => (
              <div class="project-photo-item group relative aspect-square overflow-hidden rounded-xl shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 cursor-zoom-in">
                <img
                  src={urlFor(photo.image).width(400).height(400).fit('crop').quality(80).url()}
                  alt={getLocaleString(photo.caption, lang) || `Phase ${i + 1}`}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3">
                  {photo.caption && (
                    <p class="text-white text-sm font-medium truncate">
                      {getLocaleString(photo.caption, lang)}
                    </p>
                  )}
                  {photo.date && (
                    <p class="text-white/70 text-xs mt-1">{photo.date}</p>
                  )}
                </div>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                  <svg class="w-8 h-8 text-white drop-shadow-lg" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                  </svg>
                </div>
                <input type="hidden" class="full-url" value={urlFor(photo.image).width(1920).quality(90).url()} />
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- 6. Navigation Buttons -->
  <section class="py-20">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center justify-center gap-6">
        <a 
          href="/contact"
          class="w-full md:w-auto px-8 py-4 bg-gradient-to-r from-secondary to-accent text-white font-bold rounded-lg hover:shadow-lg hover:scale-105 transition-all duration-300 text-center"
        >
          {t('contactUs', lang)}
        </a>
        
        <a 
          href={isCompleted ? "/portfolio" : "/current-projects"}
          class="w-full md:w-auto px-8 py-4 bg-white dark:bg-primary border-2 border-secondary text-secondary font-bold rounded-lg hover:bg-secondary hover:text-white transition-all duration-300 text-center"
        >
          {isCompleted 
            ? (lang === 'ar' ? 'العودة للمعرض' : 'Back to Portfolio')
            : (lang === 'ar' ? 'العودة للمشاريع الحالية' : 'Back to Current Projects')}
        </a>
      </div>
    </div>
  </section>

  <!-- Project Lightbox Overlay -->
  <div id="project-lightbox" class="fixed inset-0 z-50 bg-black/90 backdrop-blur-sm hidden items-center justify-center" role="dialog" aria-modal="true">
    <button id="plb-close" class="absolute top-4 end-4 z-10 text-white/80 hover:text-white p-2 transition-colors" aria-label="Close">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <button id="plb-prev" class="absolute start-4 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 bg-white/10 rounded-full hover:bg-white/20 transition-all" aria-label="Previous">
      <svg class="w-6 h-6 rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button id="plb-next" class="absolute end-4 top-1/2 -translate-y-1/2 z-10 text-white/80 hover:text-white p-2 bg-white/10 rounded-full hover:bg-white/20 transition-all" aria-label="Next">
      <svg class="w-6 h-6 rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>
    <img id="plb-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] object-contain rounded-lg shadow-2xl transition-opacity duration-300" />
    <p id="plb-caption" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white text-sm bg-black/50 px-4 py-2 rounded-full backdrop-blur-sm"></p>
  </div>

</BaseLayout>

<script>
  function initProjectLightbox() {
    const lightbox = document.getElementById('project-lightbox');
    const lightboxImg = document.getElementById('plb-img') as HTMLImageElement | null;
    const lightboxCaption = document.getElementById('plb-caption');
    const closeBtn = document.getElementById('plb-close');
    const prevBtn = document.getElementById('plb-prev');
    const nextBtn = document.getElementById('plb-next');

    if (!lightbox || !lightboxImg) return;

    const allItems = Array.from(document.querySelectorAll('.project-photo-item')) as HTMLElement[];
    if (allItems.length === 0) return;

    let currentIndex = -1;

    function openLightbox(index: number) {
      if (index < 0 || index >= allItems.length) return;
      currentIndex = index;
      const item = allItems[index];
      const fullUrl = item.querySelector('.full-url') as HTMLInputElement;
      const alt = item.querySelector('img')?.alt || '';
      const caption = item.querySelector('p')?.textContent || '';

      lightboxImg!.src = fullUrl?.value || '';
      lightboxImg!.alt = alt;
      if (lightboxCaption) {
        lightboxCaption.textContent = caption;
        lightboxCaption.style.display = caption ? '' : 'none';
      }

      lightbox!.classList.remove('hidden');
      lightbox!.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox!.classList.add('hidden');
      lightbox!.classList.remove('flex');
      document.body.style.overflow = '';
      currentIndex = -1;
    }

    function navigateLightbox(direction: number) {
      const newIndex = currentIndex + direction;
      if (newIndex >= 0 && newIndex < allItems.length) {
        openLightbox(newIndex);
      }
    }

    // Click on photo to open
    allItems.forEach((item, i) => {
      item.addEventListener('click', () => openLightbox(i));
    });

    closeBtn?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', () => navigateLightbox(-1));
    nextBtn?.addEventListener('click', () => navigateLightbox(1));

    // Close on background click
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') navigateLightbox(document.documentElement.dir === 'rtl' ? 1 : -1);
      if (e.key === 'ArrowRight') navigateLightbox(document.documentElement.dir === 'rtl' ? -1 : 1);
    });
  }

  document.addEventListener('DOMContentLoaded', initProjectLightbox);
  document.addEventListener('astro:page-load', initProjectLightbox);
</script>

