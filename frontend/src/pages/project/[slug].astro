---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BeforeAfterSlider from '../../components/BeforeAfterSlider';
import FloatingActionButton from '../../components/FloatingActionButton';
import { sanityClient, urlFor } from '../../lib/sanity';
import { getLocaleString, t } from '../../lib/i18n';
import type { Project } from '../../lib/types';

export const prerender = false; // Ensure SSR

const { slug } = Astro.params;
const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

if (!slug) {
  return Astro.redirect('/404');
}

// Fetch project
const project: Project = await sanityClient.fetch(`
  *[_type == "project" && slug.current == $slug][0]{
    ...,
    progressPhotos[] {
      image,
      caption,
      date
    },
    relatedProducts[]->{
      _id,
      name,
      slug
    }
  }
`, { slug });

if (!project) {
  return Astro.redirect('/404');
}

const title = getLocaleString(project.title, lang);
const isCompleted = project.status === 'completed';
const mainImage = project.afterImage || project.beforeImage;
const hasBeforeAfter = project.beforeImage && project.afterImage;
---

<BaseLayout 
  title={title}
  description={getLocaleString(project.description, lang)}
  image={mainImage ? urlFor(mainImage).width(1200).url() : undefined}
>
  <FloatingActionButton client:load mode="simple" lang={lang} />

  <!-- 1. Project Name -->
  <section class="pt-32 pb-10 bg-extra-1 dark:bg-primary text-center">
    <div class="container">
      <h1 class="text-4xl md:text-6xl font-bold text-primary dark:text-white mb-4">
        {title}
      </h1>
      <div class="flex items-center justify-center gap-4 text-sm md:text-base text-secondary">
        {/* Status Badge */}
        <span class={`px-4 py-1.5 rounded-full font-medium flex items-center gap-2 ${
          isCompleted 
            ? 'bg-green-500/10 text-green-600 dark:text-green-400' 
            : 'bg-amber-500/10 text-amber-600 dark:text-amber-400'
        }`}>
          {isCompleted ? (
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          ) : (
            <span class="w-2 h-2 bg-amber-500 rounded-full animate-pulse"></span>
          )}
          {isCompleted ? t('completed', lang) : t('active', lang)}
        </span>
        {project.category && (
          <span class="px-3 py-1 bg-secondary/10 rounded-full">
            {project.category === 'interior' ? (lang === 'ar' ? 'داخلي' : 'Interior') :
             project.category === 'exterior' ? (lang === 'ar' ? 'خارجي' : 'Exterior') :
             (lang === 'ar' ? 'داخلي وخارجي' : 'Interior & Exterior')}
          </span>
        )}
        {project.year && (
          <span class="px-3 py-1 bg-secondary/10 rounded-full">
            {project.year}
          </span>
        )}
      </div>
      {/* Location & Start Date */}
      <div class="flex items-center justify-center gap-6 mt-4 text-sm text-extra-2 dark:text-secondary/60">
        {project.location && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {getLocaleString(project.location, lang)}
          </span>
        )}
        {project.startDate && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {project.startDate}
          </span>
        )}
      </div>
    </div>
  </section>

  <!-- 2. Before & After Slider OR Main Image -->
  <section class="w-full h-[60vh] md:h-[80vh] relative bg-black">
    {hasBeforeAfter ? (
      <BeforeAfterSlider 
        client:visible
        beforeImage={urlFor(project.beforeImage!).width(1920).quality(90).url()}
        afterImage={urlFor(project.afterImage!).width(1920).quality(90).url()}
        beforeAlt={lang === 'ar' ? 'قبل' : 'Before'}
        afterAlt={lang === 'ar' ? 'بعد' : 'After'}
      />
    ) : mainImage ? (
      <img
        src={urlFor(mainImage).width(1920).quality(90).url()}
        alt={getLocaleString(project.title, lang)}
        class="w-full h-full object-cover"
      />
    ) : null}
  </section>

  <!-- 3. Project Info -->
  <section class="py-20 bg-white dark:bg-primary/50">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-8 text-center">
          {lang === 'ar' ? 'تفاصيل المشروع' : 'Project Details'}
        </h2>
        
        {project.description && (
          <div class="prose dark:prose-invert max-w-none mb-12 text-lg leading-relaxed text-center">
            <p>{getLocaleString(project.description, lang)}</p>
          </div>
        )}

        {/* Materials Used */}
        {project.relatedProducts && project.relatedProducts.length > 0 && (
          <div class="bg-extra-1 dark:bg-primary p-8 rounded-2xl border border-secondary/10">
            <h3 class="text-xl font-bold mb-6 text-center">
              {t('materialsUsed', lang)}
            </h3>
            <div class="flex flex-wrap justify-center gap-4">
              {project.relatedProducts.map((product) => (
                <a
                  href={`/products/${product.slug.current}`}
                  class="flex items-center gap-2 px-6 py-3 bg-white dark:bg-primary/50 rounded-lg shadow-sm hover:shadow-md hover:scale-105 transition-all duration-300 border border-secondary/20"
                >
                  <span class="font-medium">
                    {getLocaleString(product.name, lang)}
                  </span>
                  <svg class="w-4 h-4 text-secondary rtl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- 4. Photos Section -->
  {!isCompleted && project.progressPhotos && project.progressPhotos.length > 0 && (
    <!-- Active: Progress Photos (progressPhotos + gallery merged) -->
    <section class="py-20 bg-extra-1/30 dark:bg-black/20">
      <div class="container">
        <h2 class="text-3xl font-bold mb-12 text-center">
          {t('progressPhotos', lang)}
        </h2>
        
        {project.progressPhotos && project.progressPhotos.length > 0 && (
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 mb-12">
            {project.progressPhotos
              .sort((a, b) => {
                if (!a.date && !b.date) return 0;
                if (!a.date) return 1;
                if (!b.date) return -1;
                return new Date(b.date).getTime() - new Date(a.date).getTime();
              })
              .map((photo, i) => (
              <div class="group relative aspect-square overflow-hidden rounded-xl shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <img
                  src={urlFor(photo.image).width(400).height(400).fit('crop').quality(80).url()}
                  alt={getLocaleString(photo.caption, lang) || `Progress ${i + 1}`}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3">
                  {photo.caption && (
                    <p class="text-white text-sm font-medium truncate">
                      {getLocaleString(photo.caption, lang)}
                    </p>
                  )}
                  {photo.date && (
                    <p class="text-white/70 text-xs mt-1">{photo.date}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  {isCompleted && project.progressPhotos && project.progressPhotos.length > 0 && (
    <!-- Completed: Project Gallery (progressPhotos + gallery combined) -->
    <section class="py-20 bg-extra-1/30 dark:bg-black/20">
      <div class="container">
        <h2 class="text-3xl font-bold mb-12 text-center">
          {lang === 'ar' ? 'معرض المشروع' : 'Project Gallery'}
        </h2>
        
        {/* Progress photos as grid */}
        {project.progressPhotos && project.progressPhotos.length > 0 && (
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6 mb-12">
            {project.progressPhotos
              .sort((a, b) => {
                if (!a.date && !b.date) return 0;
                if (!a.date) return 1;
                if (!b.date) return -1;
                return new Date(b.date).getTime() - new Date(a.date).getTime();
              })
              .map((photo, i) => (
              <div class="group relative aspect-square overflow-hidden rounded-xl shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
                <img
                  src={urlFor(photo.image).width(400).height(400).fit('crop').quality(80).url()}
                  alt={getLocaleString(photo.caption, lang) || `Phase ${i + 1}`}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3">
                  {photo.caption && (
                    <p class="text-white text-sm font-medium truncate">
                      {getLocaleString(photo.caption, lang)}
                    </p>
                  )}
                  {photo.date && (
                    <p class="text-white/70 text-xs mt-1">{photo.date}</p>
                  )}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </section>
  )}

  <!-- 6. Navigation Buttons -->
  <section class="py-20">
    <div class="container">
      <div class="flex flex-col md:flex-row items-center justify-center gap-6">
        <a 
          href="/contact"
          class="w-full md:w-auto px-8 py-4 bg-gradient-to-r from-secondary to-accent text-white font-bold rounded-lg hover:shadow-lg hover:scale-105 transition-all duration-300 text-center"
        >
          {t('contactUs', lang)}
        </a>
        
        <a 
          href={isCompleted ? "/portfolio" : "/current-projects"}
          class="w-full md:w-auto px-8 py-4 bg-white dark:bg-primary border-2 border-secondary text-secondary font-bold rounded-lg hover:bg-secondary hover:text-white transition-all duration-300 text-center"
        >
          {isCompleted 
            ? (lang === 'ar' ? 'العودة للمعرض' : 'Back to Portfolio')
            : (lang === 'ar' ? 'العودة للمشاريع الحالية' : 'Back to Current Projects')}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
