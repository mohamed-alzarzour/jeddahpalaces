---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductImageSlider from '../../components/ProductImageSlider';
import EmptyState from '../../components/EmptyState.astro';
import FloatingActionButton from '../../components/FloatingActionButton';
import { sanityClient, urlFor } from '../../lib/sanity';
import { getLanguage, t, getLocaleString } from '../../lib/i18n';
import type { Product, Project } from '../../lib/types';

export const prerender = false;

const { slug } = Astro.params;
const lang = Astro.locals.lang as 'ar' | 'en' || 'ar';

// Fetch product
const product: Product = await sanityClient.fetch(`
  *[_type == "product" && slug.current == $slug][0]
`, { slug });

if (!product) {
  return Astro.redirect('/404');
}

// Fetch projects that use this product (reverse reference)
const relatedProjects: Project[] = await sanityClient.fetch(`
  *[_type == "project" && references($productId)]{
    _id,
    title,
    slug,
    beforeImage,
    afterImage
  }
`, { productId: product._id });

const galleryImages = product.gallery 
  ? [product.mainImage, ...product.gallery]
  : [product.mainImage];

const imageUrls = galleryImages.map(img => 
  urlFor(img).width(800).quality(90).url()
);
---

<BaseLayout 
  title={getLocaleString(product.name, lang)}
  description={getLocaleString(product.description, lang)}
  image={urlFor(product.mainImage).width(1200).url()}
>
  <FloatingActionButton client:load mode="simple" lang={lang} />
  <section class="py-20">
    <div class="container">
      <!-- Top Section: Product Gallery & Info -->
      <div class="grid lg:grid-cols-4 gap-8 mb-16">
        <!-- Product Gallery (3/4 width on desktop) -->
        <div class="lg:col-span-3 order-2 lg:order-1">
          <div class="aspect-square lg:aspect-video w-full bg-white dark:bg-primary/30 rounded-2xl overflow-hidden shadow-2xl">
            <ProductImageSlider
              client:load
              images={imageUrls}
              autoRotate={false}
              interval={5000}
            />
          </div>
        </div>

        <!-- Product Info (1/4 width on desktop) -->
        <div class="lg:col-span-1 order-1 lg:order-2 space-y-6">
          <div>
            <h1 class="text-3xl md:text-4xl font-bold mb-4">
              {getLocaleString(product.name, lang)}
            </h1>

            {product.category && (
              <span class="inline-block px-4 py-2 bg-secondary/10 text-secondary text-sm font-medium rounded-full mb-4">
                {product.category.replace('-', ' ').toUpperCase()}
              </span>
            )}

            {product.description && (
              <p class="text-extra-2 dark:text-secondary/70 leading-relaxed whitespace-pre-line">
                {getLocaleString(product.description, lang)}
              </p>
            )}
          </div>

          {/* Specifications */}
          {product.specifications && product.specifications.length > 0 && (
            <div>
              <h2 class="font-bold text-xl mb-4">{t('specifications', lang)}</h2>
              <div class="space-y-3">
                {product.specifications.map((spec) => (
                  <div class="border-b border-secondary/20 pb-3 last:border-0">
                    <div class="text-sm text-extra-2 dark:text-secondary/60 mb-1">
                      {getLocaleString(spec.label, lang)}
                    </div>
                    <div class="font-medium">
                      {getLocaleString(spec.value, lang)}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          <a 
            href="/contact"
            class="block text-center px-6 py-3 bg-gradient-to-r from-secondary to-accent text-white font-semibold rounded-lg hover:shadow-2xl hover:scale-105 transition-all duration-300"
          >
            {t('contactUs', lang)}
          </a>
        </div>
      </div>

      <!-- Bottom Section: Related Projects -->
      {relatedProjects.length > 0 && (
        <div>
          <h2 class="text-3xl font-bold mb-8 text-center">
            {t('relatedProjects', lang)}
          </h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            {relatedProjects.map((project) => (
              <a 
                href={`/project/${project.slug.current}`}
                class="group relative aspect-video rounded-lg overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2"
              >
                <img 
                  src={urlFor(project.afterImage || project.beforeImage).width(600).height(400).fit('crop').url()}
                  alt={getLocaleString(project.title, lang)}
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent flex items-end p-4">
                  <h3 class="text-white font-bold text-lg">
                    {getLocaleString(project.title, lang)}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      {relatedProjects.length === 0 && (
        <div class="text-center py-12">
          <p class="text-extra-2 dark:text-secondary/70 text-lg">
            {lang === 'ar' 
              ? 'لا توجد مشاريع تستخدم هذا المنتج حالياً' 
              : 'No projects using this product yet'
            }
          </p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-extra-1 dark:bg-primary/20">
    <div class="container text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        {lang === 'ar' ? 'مهتم بهذا المنتج؟' : 'Interested in this Product?'}
      </h2>
      <p class="text-lg text-extra-2 dark:text-secondary/70 mb-6">
        {lang === 'ar' ? 'اتصل بنا للحصول على مزيد من المعلومات' : 'Contact us for more information'}
      </p>
      <a 
        href="/contact"
        class="inline-block px-8 py-4 bg-gradient-to-r from-secondary to-accent text-white font-semibold rounded-lg hover:shadow-2xl hover:scale-105 transition-all duration-300"
      >
        {t('contactUs', lang)}
      </a>
    </div>
  </section>
</BaseLayout>
